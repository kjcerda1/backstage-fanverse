# ─── Backstage V16 — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in values. .env is never committed to git.
#
# The app runs in full mock/localStorage mode with NO variables set.
# Only add variables when you're ready for real integrations.

# ── App ─────────────────────────────────────────────────────────────────────
VITE_APP_ENV=production
VITE_APP_VERSION=1.6.0

# ── Backend API proxy (optional) ──────────────────────────────────────────
# Leave blank to run in mock mode (all features work locally)
VITE_API_URL=

# ── Supabase (optional — enables real auth + database) ──────────────────
# Get these from https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Mapbox (optional — enables real geographic fan map) ──────────────────
# Get this from https://mapbox.com → Access Tokens
VITE_MAPBOX_TOKEN=
