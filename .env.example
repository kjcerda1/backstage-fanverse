# ─── Backstage V16 — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in values. .env is never committed to git.
#
# The app runs in full mock/localStorage mode with NO variables set.
# Only add variables when you're ready for real integrations.

# ── App ─────────────────────────────────────────────────────────────────────
VITE_APP_ENV=production
VITE_APP_VERSION=1.6.0

# ── Backend API proxy (optional) ──────────────────────────────────────────
# Leave blank to run in mock mode (all features work locally)
VITE_API_URL=

# ── Supabase (optional — enables real auth + database) ──────────────────
# Get these from https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Mapbox (optional — enables real geographic fan map) ──────────────────
# Get this from https://mapbox.com → Access Tokens
VITE_MAPBOX_TOKEN=

# ── Ticketmaster (Phase 2 — server-side only, NEVER prefix with VITE_) ──
# Get this from https://developer.ticketmaster.com → My Apps → API Key
# Used by backend GET /api/events to sync K-pop events via Discovery API.
# Phase 2: wire ConcertsPage to call GET /api/events with user.fandoms filter.
# Phase 3: nightly sync job → Supabase events table → frontend renders live data.
TICKETMASTER_API_KEY=

# ── Firebase / FCM (Phase 3 — device push notifications) ────────────────
# Get these from https://console.firebase.google.com → Project Settings → General
# These VITE_ vars are safe for the browser bundle (public config, not secret).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VAPID key: Firebase Console → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=

# Backend-only Firebase credentials (service account — NEVER expose these).
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Use FCM HTTP v1 API (not deprecated legacy server key).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Important: wrap private key in quotes and preserve literal \n characters.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
